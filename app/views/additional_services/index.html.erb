<% if notice.present? %>
  <div class="bg-green-50 text-green-500 p-4 rounded-lg mb-6" role="alert">
    <%= notice %>
  </div>
<% end %>

<% content_for :title, "Additional Services" %>

<div class="flex justify-between items-center mb-6">
  <h1 class="text-2xl font-bold text-gray-900">Additional Services</h1>
  <%= link_to new_additional_service_path, class: "px-4 py-2 bg-blue-600 text-white rounded-md hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500" do %>
    <i class="fas fa-plus mr-2"></i> New Additional Service
  <% end %>
</div>

<div class="bg-white shadow overflow-hidden sm:rounded-lg">
  <table class="min-w-full divide-y divide-gray-200">
    <thead class="bg-gray-50">
      <tr>
        <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Name</th>
        <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Price</th>
        <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Actions</th>
      </tr>
    </thead>
    <tbody class="bg-white divide-y divide-gray-200">
      <% @additional_services.each do |additional_service| %>
        <tr class="hover:bg-gray-50">
          <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900"><%= additional_service.name %></td>
          <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500"><%= number_to_currency(additional_service.price) %></td>
          <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500 space-x-2">
            <%= link_to "View", additional_service, class: "text-blue-600 hover:text-blue-900" %>
            <%= link_to "Edit", edit_additional_service_path(additional_service), class: "text-indigo-600 hover:text-indigo-900" %>
            <%= button_to "Delete", additional_service, method: :delete, form: { data: { turbo_confirm: "Are you sure?" } }, class: "text-red-600 hover:text-red-900 bg-transparent border-0 p-0 cursor-pointer" %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>

<div class="mt-4">
  <%= link_to "Back to Home", root_path, class: "text-blue-600 hover:text-blue-900" %>
</div>
