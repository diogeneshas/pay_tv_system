<% if notice.present? %>
  <div class="bg-green-50 text-green-500 p-4 rounded-lg mb-6" role="alert">
    <%= notice %>
  </div>
<% end %>

<% content_for :title, @additional_service.name %>

<div class="flex justify-between items-center mb-6">
  <h1 class="text-2xl font-bold text-gray-900"><%= @additional_service.name %></h1>
  <div class="flex space-x-2">
    <%= link_to edit_additional_service_path(@additional_service), class: "px-4 py-2 bg-indigo-600 text-white rounded-md hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500" do %>
      <i class="fas fa-edit mr-2"></i> Edit
    <% end %>
    <%= button_to @additional_service, method: :delete, form: { data: { turbo_confirm: "Are you sure you want to delete this additional service?" } }, class: "px-4 py-2 bg-red-600 text-white rounded-md hover:bg-red-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-red-500" do %>
      <i class="fas fa-trash mr-2"></i> Delete
    <% end %>
  </div>
</div>

<%= render @additional_service %>

<div class="mt-6 flex space-x-4">
  <%= link_to "Back to Additional Services", additional_services_path, class: "text-blue-600 hover:text-blue-900" %>
  <%= link_to "Back to Home", root_path, class: "text-blue-600 hover:text-blue-900" %>
</div>
