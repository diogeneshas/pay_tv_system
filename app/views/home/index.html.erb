<div class="bg-white overflow-hidden shadow rounded-lg">
  <div class="px-4 py-5 sm:p-6">
    <h1 class="text-3xl font-bold text-gray-900 mb-6">Sistema de Gestão de TV por Assinatura</h1>
    
    <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-6">
      <!-- Plans Button -->
      <div class="relative group">
        <%= link_to plans_path, class: "w-full flex flex-col items-center p-6 bg-blue-50 rounded-lg border border-blue-200 hover:bg-blue-100 transition-all duration-200" do %>
          <div class="flex items-center justify-center h-12 w-12 rounded-md bg-blue-500 text-white mb-4">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />
            </svg>
          </div>
          <h3 class="text-lg font-medium text-gray-900">Planos</h3>
          <p class="mt-2 text-sm text-gray-500 text-center">Gerenciar planos base do sistema</p>
        <% end %>
      </div>

      <!-- Packages Button -->
      <div class="relative group">
        <%= link_to packages_path, class: "w-full flex flex-col items-center p-6 bg-green-50 rounded-lg border border-green-200 hover:bg-green-100 transition-all duration-200" do %>
          <div class="flex items-center justify-center h-12 w-12 rounded-md bg-green-500 text-white mb-4">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" />
            </svg>
          </div>
          <h3 class="text-lg font-medium text-gray-900">Pacotes</h3>
          <p class="mt-2 text-sm text-gray-500 text-center">Gerenciar pacotes de serviços</p>
        <% end %>
      </div>

      <!-- Additional Services Button -->
      <div class="relative group">
        <%= link_to additional_services_path, class: "w-full flex flex-col items-center p-6 bg-purple-50 rounded-lg border border-purple-200 hover:bg-purple-100 transition-all duration-200" do %>
          <div class="flex items-center justify-center h-12 w-12 rounded-md bg-purple-500 text-white mb-4">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6" />
            </svg>
          </div>
          <h3 class="text-lg font-medium text-gray-900">Serviços Adicionais</h3>
          <p class="mt-2 text-sm text-gray-500 text-center">Gerenciar serviços adicionais</p>
        <% end %>
      </div>

      <!-- Clients Button -->
      <div class="relative group">
        <%= link_to clients_path, class: "w-full flex flex-col items-center p-6 bg-yellow-50 rounded-lg border border-yellow-200 hover:bg-yellow-100 transition-all duration-200" do %>
          <div class="flex items-center justify-center h-12 w-12 rounded-md bg-yellow-500 text-white mb-4">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
            </svg>
          </div>
          <h3 class="text-lg font-medium text-gray-900">Clientes</h3>
          <p class="mt-2 text-sm text-gray-500 text-center">Gerenciar clientes</p>
        <% end %>
      </div>
      
      <!-- Subscriptions Button -->
      <div class="relative group">
        <%= link_to subscriptions_path, class: "w-full flex flex-col items-center p-6 bg-indigo-50 rounded-lg border border-indigo-200 hover:bg-indigo-100 transition-all duration-200" do %>
          <div class="flex items-center justify-center h-12 w-12 rounded-md bg-indigo-500 text-white mb-4">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9" />
            </svg>
          </div>
          <h3 class="text-lg font-medium text-gray-900">Assinaturas</h3>
          <p class="mt-2 text-sm text-gray-500 text-center">Gerenciar assinaturas de clientes</p>
        <% end %>
      </div>
      
      <!-- Subscription Additional Services Button -->
      <div class="relative group">
        <%= link_to subscription_additional_services_path, class: "w-full flex flex-col items-center p-6 bg-pink-50 rounded-lg border border-pink-200 hover:bg-pink-100 transition-all duration-200" do %>
          <div class="flex items-center justify-center h-12 w-12 rounded-md bg-pink-500 text-white mb-4">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
            </svg>
          </div>
          <h3 class="text-lg font-medium text-gray-900">Serviços da Assinatura</h3>
          <p class="mt-2 text-sm text-gray-500 text-center">Gerenciar serviços adicionais das assinaturas</p>
        <% end %>
      </div>
    </div>
  </div>
</div>

<div class="mt-8 bg-white overflow-hidden shadow rounded-lg">
  <div class="px-4 py-5 sm:p-6">
    <h2 class="text-xl font-semibold text-gray-900 mb-4">Sobre o Sistema</h2>
    <p class="text-gray-600 mb-3">O sistema de TV por assinatura gerencia os seguintes componentes principais:</p>
    
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mt-6">
      <div class="bg-gray-50 p-4 rounded-lg border border-gray-200">
        <h3 class="font-medium text-gray-900">Planos e Pacotes</h3>
        <ul class="mt-2 text-sm text-gray-600 list-disc pl-5 space-y-1">
          <li>Planos base com preços definidos</li>
          <li>Pacotes que combinam planos e serviços adicionais</li>
          <li>Cálculo automático de preço baseado nos componentes</li>
        </ul>
      </div>
      
      <div class="bg-gray-50 p-4 rounded-lg border border-gray-200">
        <h3 class="font-medium text-gray-900">Serviços Adicionais</h3>
        <ul class="mt-2 text-sm text-gray-600 list-disc pl-5 space-y-1">
          <li>Gerenciamento de serviços extras</li>
          <li>Todo pacote deve ter pelo menos um serviço adicional</li>
          <li>Preços individuais para cada serviço</li>
        </ul>
      </div>
      
      <div class="bg-gray-50 p-4 rounded-lg border border-gray-200">
        <h3 class="font-medium text-gray-900">Assinaturas</h3>
        <ul class="mt-2 text-sm text-gray-600 list-disc pl-5 space-y-1">
          <li>Associação de clientes a pacotes</li>
          <li>Controle de período de vigência</li>
          <li>Gerenciamento de serviços adicionais por assinatura</li>
        </ul>
      </div>
    </div>
  </div>
</div>
