<% if notice.present? %>
  <div class="bg-green-50 text-green-500 p-4 rounded-lg mb-6" role="alert">
    <%= notice %>
  </div>
<% end %>

<% content_for :title, "Packages" %>

<div class="flex justify-between items-center mb-6">
  <h1 class="text-2xl font-bold text-gray-900">Packages</h1>
  <%= link_to new_package_path, class: "px-4 py-2 bg-blue-600 text-white rounded-md hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500" do %>
    <i class="fas fa-plus mr-2"></i> New Package
  <% end %>
</div>

<div class="bg-white shadow overflow-hidden sm:rounded-lg">
  <table class="min-w-full divide-y divide-gray-200">
    <thead class="bg-gray-50">
      <tr>
        <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Name</th>
        <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Price</th>
        <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Plan</th>
        <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Additional Service</th>
        <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Actions</th>
      </tr>
    </thead>
    <tbody class="bg-white divide-y divide-gray-200">
      <% @packages.each do |package| %>
        <tr class="hover:bg-gray-50">
          <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900"><%= package.name %></td>
          <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500"><%= number_to_currency(package.price) %></td>
          <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
            <% if package.plan %>
              <%= link_to package.plan.name, package.plan, class: "text-blue-600 hover:text-blue-900" %>
            <% else %>
              <span class="text-red-500">None</span>
            <% end %>
          </td>
          <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
            <% if package.additional_service %>
              <%= link_to package.additional_service.name, package.additional_service, class: "text-blue-600 hover:text-blue-900" %>
            <% else %>
              <span class="text-red-500">None</span>
            <% end %>
          </td>
          <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500 space-x-2">
            <%= link_to "View", package, class: "text-blue-600 hover:text-blue-900" %>
            <%= link_to "Edit", edit_package_path(package), class: "text-indigo-600 hover:text-indigo-900" %>
            <%= button_to "Delete", package, method: :delete, form: { data: { turbo_confirm: "Are you sure?" } }, class: "text-red-600 hover:text-red-900 bg-transparent border-0 p-0 cursor-pointer" %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>

<div class="mt-4">
  <%= link_to "Back to Home", root_path, class: "text-blue-600 hover:text-blue-900" %>
</div>
