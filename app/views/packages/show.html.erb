<% if notice.present? %>
  <div class="bg-green-50 text-green-500 p-4 rounded-lg mb-6" role="alert">
    <%= notice %>
  </div>
<% end %>

<% content_for :title, "#{@package.name} | Package Details" %>

<div class="flex justify-between items-center mb-6">
  <h1 class="text-2xl font-bold text-gray-900">Package Details</h1>
  <div class="flex space-x-2">
    <%= link_to edit_package_path(@package), class: "px-4 py-2 bg-indigo-600 text-white rounded-md hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500" do %>
      <i class="fas fa-edit mr-2"></i> Edit
    <% end %>
    <%= button_to @package, method: :delete, form: { data: { turbo_confirm: "Are you sure you want to delete this package?" } }, class: "px-4 py-2 bg-red-600 text-white rounded-md hover:bg-red-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-red-500" do %>
      <i class="fas fa-trash mr-2"></i> Delete
    <% end %>
  </div>
</div>

<%= render @package %>

<div class="mt-6">
  <h2 class="text-xl font-semibold text-gray-900 mb-4">Subscriptions</h2>
  <% if @package.subscriptions.any? %>
    <div class="bg-white shadow overflow-hidden sm:rounded-lg">
      <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-gray-50">
          <tr>
            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Client</th>
            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Start Date</th>
            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">End Date</th>
            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Status</th>
            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Actions</th>
          </tr>
        </thead>
      </table>
    </div>
  <% else %>
    <p class="text-gray-500 italic">This package has no subscriptions yet.</p>
  <% end %>
</div>

<div class="mt-6 flex space-x-4">
  <%= link_to "Back to Packages", packages_path, class: "text-blue-600 hover:text-blue-900" %>
  <%= link_to "Back to Home", root_path, class: "text-blue-600 hover:text-blue-900" %>
</div>
