<div class="min-h-screen bg-gray-100">
  <div class="py-10">
    <header>
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex justify-between items-center">
        <div class="flex justify-between items-center mb-4">
          <h1 class="text-3xl font-bold text-gray-900">Serviços Adicionais das Assinaturas</h1>
          <%= link_to 'Voltar', root_path, class: "px-4 py-2 bg-gray-200 rounded-md text-gray-700 hover:bg-gray-300" %>
        </div>
      </div>
    </header>
    <main>
      <div class="max-w-7xl mx-auto sm:px-6 lg:px-8">
        <div class="px-4 py-8 sm:px-0">
          <div class="bg-white overflow-hidden shadow rounded-lg">
            <div class="px-4 py-5 sm:p-6">
              <div class="flex justify-between items-center mb-6">
                <h2 class="text-lg leading-6 font-medium text-gray-900">Lista de Serviços Adicionais das Assinaturas</h2>
                <%= link_to 'Novo Serviço Adicional', new_subscription_additional_service_path, class: "px-4 py-2 bg-pink-600 rounded-md text-white hover:bg-pink-700" %>
              </div>
              
              <div class="overflow-x-auto">
                <table class="min-w-full divide-y divide-gray-200">
                  <thead class="bg-gray-50">
                    <tr>
                      <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Assinatura</th>
                      <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Cliente</th>
                      <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Serviço Adicional</th>
                      <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Preço</th>
                      <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Ações</th>
                    </tr>
                  </thead>
                  <tbody class="bg-white divide-y divide-gray-200">
                    <% if @subscription_additional_services.any? %>
                      <% @subscription_additional_services.each do |subscription_additional_service| %>
                        <tr>
                          <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500"><%= subscription_additional_service.subscription_id %></td>
                          <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500"><%= subscription_additional_service.subscription&.client&.name || 'N/A' %></td>
                          <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500"><%= subscription_additional_service.additional_service&.name || 'N/A' %></td>
                          <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500"><%= number_to_currency(subscription_additional_service.additional_service&.price) || 'N/A' %></td>
                          <td class="px-6 py-4 whitespace-nowrap text-sm font-medium">
                            <%= link_to 'Ver', subscription_additional_service_path(subscription_additional_service), class: "text-indigo-600 hover:text-indigo-900 mr-4" %>
                            <%= link_to 'Editar', edit_subscription_additional_service_path(subscription_additional_service), class: "text-yellow-600 hover:text-yellow-900 mr-4" %>
                            <%= link_to 'Excluir', subscription_additional_service_path(subscription_additional_service), method: :delete, data: { confirm: 'Tem certeza?' }, class: "text-red-600 hover:text-red-900" %>
                          </td>
                        </tr>
                      <% end %>
                    <% else %>
                      <tr>
                        <td colspan="5" class="px-6 py-4 text-center text-sm text-gray-500">Nenhum serviço adicional de assinatura encontrado</td>
                      </tr>
                    <% end %>
                  </tbody>
                </table>
              </div>
            </div>
          </div>
        </div>
      </div>
    </main>
  </div>
</div>

<div class="mt-8 bg-white overflow-hidden shadow rounded-lg">
  <div class="px-4 py-5 sm:p-6">
    <h2 class="text-xl font-semibold text-gray-900 mb-4">Informações Importantes</h2>
    
    <div class="bg-yellow-50 border-l-4 border-yellow-400 p-4 mb-4">
      <div class="flex">
        <div class="flex-shrink-0">
          <svg class="h-5 w-5 text-yellow-400" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd" />
          </svg>
        </div>
        <div class="ml-3">
          <p class="text-sm text-yellow-700">
            Lembre-se que todo pacote deve ter pelo menos um serviço adicional, conforme as regras de negócio.
          </p>
        </div>
      </div>
    </div>
    
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <div class="bg-gray-50 p-4 rounded-lg border border-gray-200">
        <h3 class="font-medium text-gray-900">Gerenciamento de Serviços</h3>
        <p class="mt-2 text-sm text-gray-600">
          Esta seção permite adicionar serviços adicionais específicos para cada assinatura de cliente.
          Os serviços adicionais podem ser personalizados de acordo com as necessidades do cliente.          
        </p>
      </div>
      
      <div class="bg-gray-50 p-4 rounded-lg border border-gray-200">
        <h3 class="font-medium text-gray-900">Cálculo de Preços</h3>
        <p class="mt-2 text-sm text-gray-600">
          O preço total da assinatura é calculado automaticamente somando o valor do plano base
          e todos os serviços adicionais vinculados à assinatura.
        </p>
      </div>
    </div>
  </div>
</div>
