<div class="flex justify-between items-center mb-4">
  <h1 class="text-3xl font-bold text-gray-900">Detalhes do Serviço Adicional</h1>
  <div class="flex space-x-2">
    <%= link_to 'Editar', edit_subscription_additional_service_path(@subscription_additional_service), class: "px-4 py-2 bg-yellow-500 rounded-md text-white hover:bg-yellow-600" %>
    <%= link_to 'Voltar', subscription_additional_services_path, class: "px-4 py-2 bg-gray-200 rounded-md text-gray-700 hover:bg-gray-300" %>
  </div>
</div>

<div class="bg-white overflow-hidden shadow rounded-lg">
  <div class="px-4 py-5 sm:p-6">
    <h2 class="text-lg leading-6 font-medium text-gray-900 mb-4">Informações do Serviço Adicional</h2>
    
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <div class="col-span-1">
        <dl class="grid grid-cols-1 gap-x-4 gap-y-6 sm:grid-cols-2">
          <div class="sm:col-span-1">
            <dt class="text-sm font-medium text-gray-500">Nome do Serviço</dt>
            <dd class="mt-1 text-sm text-gray-900"><%= @subscription_additional_service.additional_service&.name || 'N/A' %></dd>
          </div>
          
          <div class="sm:col-span-1">
            <dt class="text-sm font-medium text-gray-500">Preço</dt>
            <dd class="mt-1 text-sm text-gray-900"><%= number_to_currency(@subscription_additional_service.additional_service&.price) || 'N/A' %></dd>
          </div>
          
          <div class="sm:col-span-2">
            <dt class="text-sm font-medium text-gray-500">Descrição</dt>
            <dd class="mt-1 text-sm text-gray-900"><%= @subscription_additional_service.additional_service&.description || 'Sem descrição disponível' %></dd>
          </div>
        </dl>
      </div>
      
      <div class="col-span-1">
        <div class="bg-gray-50 p-4 rounded-md">
          <h3 class="text-sm font-medium text-gray-700 mb-2">Observações</h3>
          <div class="text-sm text-gray-600">
            <%= @subscription_additional_service.notes.present? ? @subscription_additional_service.notes : 'Nenhuma observação registrada.' %>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<div class="mt-8 bg-white overflow-hidden shadow rounded-lg">
  <div class="px-4 py-5 sm:p-6">
    <h2 class="text-lg leading-6 font-medium text-gray-900 mb-4">Detalhes da Assinatura</h2>
    
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <div class="col-span-1">
        <dl class="grid grid-cols-1 gap-x-4 gap-y-6 sm:grid-cols-2">
          <div class="sm:col-span-1">
            <dt class="text-sm font-medium text-gray-500">Cliente</dt>
            <dd class="mt-1 text-sm text-gray-900"><%= @subscription_additional_service.subscription&.client&.name || 'N/A' %></dd>
          </div>
          
          <div class="sm:col-span-1">
            <dt class="text-sm font-medium text-gray-500">Pacote</dt>
            <dd class="mt-1 text-sm text-gray-900"><%= @subscription_additional_service.subscription&.package&.name || 'N/A' %></dd>
          </div>
          
          <div class="sm:col-span-1">
            <dt class="text-sm font-medium text-gray-500">Data de Início</dt>
            <dd class="mt-1 text-sm text-gray-900"><%= @subscription_additional_service.subscription&.start_date&.strftime('%d/%m/%Y') || 'N/A' %></dd>
          </div>
          
          <div class="sm:col-span-1">
            <dt class="text-sm font-medium text-gray-500">Data de Fim</dt>
            <dd class="mt-1 text-sm text-gray-900"><%= @subscription_additional_service.subscription&.end_date&.strftime('%d/%m/%Y') || 'N/A' %></dd>
          </div>
          
          <div class="sm:col-span-1">
            <dt class="text-sm font-medium text-gray-500">Status</dt>
            <dd class="mt-1">
              <% if @subscription_additional_service.subscription&.status == 'active' %>
                <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-green-100 text-green-800">Ativo</span>
              <% elsif @subscription_additional_service.subscription&.status == 'inactive' %>
                <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-red-100 text-red-800">Inativo</span>
              <% else %>
                <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-gray-100 text-gray-800">N/A</span>
              <% end %>
            </dd>
          </div>
          
          <div class="sm:col-span-1">
            <dt class="text-sm font-medium text-gray-500">Preço Total da Assinatura</dt>
            <dd class="mt-1 text-sm text-gray-900">
              <%= number_to_currency(@subscription_additional_service.subscription&.total_price) || 'N/A' %>
            </dd>
          </div>
        </dl>
      </div>
      
      <div class="col-span-1">
        <div class="bg-blue-50 border-l-4 border-blue-400 p-4">
          <div class="flex">
            <div class="flex-shrink-0">
              <svg class="h-5 w-5 text-blue-400" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd" />
              </svg>
            </div>
            <div class="ml-3">
              <p class="text-sm text-blue-700">
                Este serviço adicional está vinculado à assinatura do cliente <%= @subscription_additional_service.subscription&.client&.name || 'N/A' %>.
                <%= link_to 'Ver todos os detalhes da assinatura', subscription_path(@subscription_additional_service.subscription), class: "font-medium underline" if @subscription_additional_service.subscription %>
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
