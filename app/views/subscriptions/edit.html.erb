<div class="flex justify-between items-center mb-4">
  <h1 class="text-3xl font-bold text-gray-900">Editar Assinatura</h1>
  <%= link_to 'Voltar', subscriptions_path, class: "px-4 py-2 bg-gray-200 rounded-md text-gray-700 hover:bg-gray-300" %>
</div>

<div class="bg-white overflow-hidden shadow rounded-lg">
  <div class="px-4 py-5 sm:p-6">
    <h2 class="text-lg leading-6 font-medium text-gray-900 mb-4">Dados da Assinatura</h2>
    
    <%= render 'form', subscription: @subscription %>
  </div>
</div>

<div class="mt-8 bg-white overflow-hidden shadow rounded-lg">
  <div class="px-4 py-5 sm:p-6">
    <h2 class="text-xl font-semibold text-gray-900 mb-4">Serviços Adicionais desta Assinatura</h2>
    
    <div class="mb-4 flex justify-between items-center">
      <p class="text-sm text-gray-600">Gerencie os serviços adicionais específicos desta assinatura.</p>
      <%= link_to 'Adicionar Serviço', new_subscription_additional_service_path(subscription_id: @subscription.id), class: "px-4 py-2 bg-pink-600 rounded-md text-white hover:bg-pink-700" %>
    </div>
    
    <div class="overflow-x-auto">
      <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-gray-50">
          <tr>
            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Serviço Adicional</th>
            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Preço</th>
            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Ações</th>
          </tr>
        </thead>
        <tbody class="bg-white divide-y divide-gray-200">
          <% if @subscription.subscription_additional_services.any? %>
            <% @subscription.subscription_additional_services.each do |service| %>
              <tr>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500"><%= service.additional_service&.name || 'N/A' %></td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500"><%= number_to_currency(service.additional_service&.price) || 'N/A' %></td>
                <td class="px-6 py-4 whitespace-nowrap text-sm font-medium">
                  <%= link_to 'Ver', subscription_additional_service_path(service), class: "text-indigo-600 hover:text-indigo-900 mr-4" %>
                  <%= link_to 'Editar', edit_subscription_additional_service_path(service), class: "text-yellow-600 hover:text-yellow-900 mr-4" %>
                  <%= link_to 'Excluir', subscription_additional_service_path(service), method: :delete, data: { confirm: 'Tem certeza?' }, class: "text-red-600 hover:text-red-900" %>
                </td>
              </tr>
            <% end %>
          <% else %>
            <tr>
              <td colspan="3" class="px-6 py-4 text-center text-sm text-gray-500">Nenhum serviço adicional vinculado a esta assinatura</td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</div>
