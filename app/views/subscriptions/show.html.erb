<div class="flex justify-between items-center mb-4">
  <h1 class="text-3xl font-bold text-gray-900">Detalhes da Assinatura</h1>
  <div class="flex space-x-2">
    <%= link_to 'Editar', edit_subscription_path(@subscription), class: "px-4 py-2 bg-yellow-500 rounded-md text-white hover:bg-yellow-600" %>
    <%= link_to 'Voltar', subscriptions_path, class: "px-4 py-2 bg-gray-200 rounded-md text-gray-700 hover:bg-gray-300" %>
  </div>
</div>

<div class="bg-white overflow-hidden shadow rounded-lg">
  <div class="px-4 py-5 sm:p-6">
    <h2 class="text-lg leading-6 font-medium text-gray-900 mb-4">Dados da Assinatura</h2>
    
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <div class="col-span-1">
        <dl class="grid grid-cols-1 gap-x-4 gap-y-6 sm:grid-cols-2">
          <div class="sm:col-span-1">
            <dt class="text-sm font-medium text-gray-500">Cliente</dt>
            <dd class="mt-1 text-sm text-gray-900"><%= @subscription.client&.name || 'N/A' %></dd>
          </div>
          
          <div class="sm:col-span-1">
            <dt class="text-sm font-medium text-gray-500">Pacote</dt>
            <dd class="mt-1 text-sm text-gray-900"><%= @subscription.package&.name || 'N/A' %></dd>
          </div>
          
          <div class="sm:col-span-1">
            <dt class="text-sm font-medium text-gray-500">Data de Início</dt>
            <dd class="mt-1 text-sm text-gray-900"><%= @subscription.start_date&.strftime('%d/%m/%Y') || 'N/A' %></dd>
          </div>
          
          <div class="sm:col-span-1">
            <dt class="text-sm font-medium text-gray-500">Data de Fim</dt>
            <dd class="mt-1 text-sm text-gray-900"><%= @subscription.end_date&.strftime('%d/%m/%Y') || 'N/A' %></dd>
          </div>
          
          <div class="sm:col-span-1">
            <dt class="text-sm font-medium text-gray-500">Status</dt>
            <dd class="mt-1">
              <% if @subscription.status == 'active' %>
                <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-green-100 text-green-800">Ativo</span>
              <% elsif @subscription.status == 'inactive' %>
                <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-red-100 text-red-800">Inativo</span>
              <% else %>
                <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-gray-100 text-gray-800"><%= @subscription.status %></span>
              <% end %>
            </dd>
          </div>
          
          <div class="sm:col-span-1">
            <dt class="text-sm font-medium text-gray-500">Preço Total</dt>
            <dd class="mt-1 text-sm text-gray-900">
              <%= number_to_currency(@subscription.total_price) || 'N/A' %>
            </dd>
          </div>
        </dl>
      </div>
      
      <div class="col-span-1">
        <div class="bg-gray-50 p-4 rounded-md">
          <h3 class="text-sm font-medium text-gray-700 mb-2">Observações</h3>
          <div class="text-sm text-gray-600">
            <%= @subscription.notes.present? ? @subscription.notes : 'Nenhuma observação registrada.' %>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<div class="mt-8 bg-white overflow-hidden shadow rounded-lg">
  <div class="px-4 py-5 sm:p-6">
    <div class="flex justify-between items-center mb-4">
      <h2 class="text-lg leading-6 font-medium text-gray-900">Serviços Adicionais desta Assinatura</h2>
      <%= link_to 'Adicionar Serviço', new_subscription_additional_service_path(subscription_id: @subscription.id), class: "px-4 py-2 bg-pink-600 rounded-md text-white hover:bg-pink-700" %>
    </div>
    
    <div class="overflow-x-auto">
      <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-gray-50">
          <tr>
            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Serviço Adicional</th>
            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Descrição</th>
            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Preço</th>
            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Ações</th>
          </tr>
        </thead>
        <tbody class="bg-white divide-y divide-gray-200">
          <% if @subscription.subscription_additional_services.any? %>
            <% @subscription.subscription_additional_services.each do |service| %>
              <tr>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500"><%= service.additional_service&.name || 'N/A' %></td>
                <td class="px-6 py-4 text-sm text-gray-500"><%= service.additional_service&.description || 'N/A' %></td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500"><%= number_to_currency(service.additional_service&.price) || 'N/A' %></td>
                <td class="px-6 py-4 whitespace-nowrap text-sm font-medium">
                  <%= link_to 'Ver', subscription_additional_service_path(service), class: "text-indigo-600 hover:text-indigo-900 mr-4" %>
                  <%= link_to 'Editar', edit_subscription_additional_service_path(service), class: "text-yellow-600 hover:text-yellow-900 mr-4" %>
                  <%= link_to 'Excluir', subscription_additional_service_path(service), method: :delete, data: { confirm: 'Tem certeza?' }, class: "text-red-600 hover:text-red-900" %>
                </td>
              </tr>
            <% end %>
          <% else %>
            <tr>
              <td colspan="4" class="px-6 py-4 text-center text-sm text-gray-500">Nenhum serviço adicional cadastrado.</td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</div>

<!-- Seção de Faturamento -->
<div class="mt-8 bg-white overflow-hidden shadow rounded-lg">
  <div class="px-4 py-5 sm:p-6">
    <div class="flex justify-between items-center mb-4">
      <h2 class="text-lg leading-6 font-medium text-gray-900">Faturamento</h2>
    </div>
    
    <!-- Carnê -->
    <div class="mb-6 bg-gray-50 p-4 rounded-md">
      <h3 class="text-md font-medium text-gray-700 mb-2">Carnê</h3>
      <% if @subscription.booklet.present? %>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
          <div>
            <p class="text-sm font-medium text-gray-500">Valor Total</p>
            <p class="text-lg font-semibold text-gray-900"><%= number_to_currency(@subscription.booklet.amount) %></p>
          </div>
          <div>
            <p class="text-sm font-medium text-gray-500">Data de Criação</p>
            <p class="text-md text-gray-900"><%= @subscription.booklet.created_at.strftime('%d/%m/%Y') %></p>
          </div>
          <div>
            <p class="text-sm font-medium text-gray-500">Período</p>
            <p class="text-md text-gray-900">
              <%= @subscription.invoices.minimum(:due_date)&.strftime('%d/%m/%Y') %> a 
              <%= @subscription.invoices.maximum(:due_date)&.strftime('%d/%m/%Y') %>
            </p>
          </div>
        </div>
      <% else %>
        <p class="text-sm text-gray-500">Nenhum carnê gerado para esta assinatura.</p>
      <% end %>
    </div>
    
    <!-- Faturas -->
    <div class="mb-6">
      <h3 class="text-md font-medium text-gray-700 mb-2">Faturas</h3>
      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-gray-200">
          <thead class="bg-gray-50">
            <tr>
              <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Mês</th>
              <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Vencimento</th>
              <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Valor</th>
              <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Status</th>
              <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Ações</th>
            </tr>
          </thead>
          <tbody class="bg-white divide-y divide-gray-200">
            <% if @subscription.invoices.any? %>
              <% @subscription.invoices.order(:due_date).each_with_index do |invoice, index| %>
                <tr>
                  <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                    <%= index + 1 %>º mês
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                    <%= invoice.due_date.strftime('%d/%m/%Y') %>
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                    <%= number_to_currency(invoice.amount) %>
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap">
                    <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-yellow-100 text-yellow-800">Pendente</span>
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap text-sm font-medium">
                    <button class="text-indigo-600 hover:text-indigo-900 mr-2" 
                            onclick="toggleAccounts(<%= invoice.id %>)">
                      Ver Detalhes
                    </button>
                  </td>
                </tr>
                <!-- Contas da fatura (inicialmente ocultas) -->
                <tr id="accounts-<%= invoice.id %>" class="hidden bg-gray-50">
                  <td colspan="5" class="px-6 py-4">
                    <div class="pl-4 border-l-2 border-indigo-500">
                      <h4 class="text-sm font-medium text-gray-700 mb-2">Contas desta fatura:</h4>
                      <table class="min-w-full divide-y divide-gray-200">
                        <thead>
                          <tr>
                            <th class="px-4 py-2 text-left text-xs font-medium text-gray-500">Item</th>
                            <th class="px-4 py-2 text-left text-xs font-medium text-gray-500">Tipo</th>
                            <th class="px-4 py-2 text-left text-xs font-medium text-gray-500">Valor</th>
                          </tr>
                        </thead>
                        <tbody>
                          <% invoice.accounts.each do |account| %>
                            <tr>
                              <td class="px-4 py-2 text-xs text-gray-500">
                                <%= account.item.name rescue 'N/A' %>
                              </td>
                              <td class="px-4 py-2 text-xs text-gray-500">
                                <% if account.item_type == 'Plan' %>
                                  Plano
                                <% elsif account.item_type == 'Package' %>
                                  Pacote
                                <% elsif account.item_type == 'AdditionalService' %>
                                  Serviço Adicional
                                <% else %>
                                  <%= account.item_type %>
                                <% end %>
                              </td>
                              <td class="px-4 py-2 text-xs text-gray-500">
                                <%= number_to_currency(account.amount) %>
                              </td>
                            </tr>
                          <% end %>
                        </tbody>
                      </table>
                    </div>
                  </td>
                </tr>
              <% end %>
            <% else %>
              <tr>
                <td colspan="5" class="px-6 py-4 text-center text-sm text-gray-500">Nenhuma fatura gerada para esta assinatura.</td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>

<script>
  function toggleAccounts(invoiceId) {
    const accountsRow = document.getElementById(`accounts-${invoiceId}`);
    if (accountsRow.classList.contains('hidden')) {
      accountsRow.classList.remove('hidden');
    } else {
      accountsRow.classList.add('hidden');
    }
  }
</script>
